# ===========================================
# ISP Hotspot Voucher & Billing System
# Environment Configuration (.env.example)
# ===========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- PostgreSQL ---
POSTGRES_DB=hotspot_db
POSTGRES_USER=hotspot_user
POSTGRES_PASSWORD=hotspot_pass

# --- Backend ---
# Async URL for SQLAlchemy async, SYNC URL for Alembic migrations (via PgBouncer)
DATABASE_URL=postgresql+asyncpg://hotspot_user:hotspot_pass@pgbouncer:5432/hotspot_db
SYNC_DATABASE_URL=postgresql://hotspot_user:hotspot_pass@pgbouncer:5432/hotspot_db

# JWT secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_in_production_must_be_long_random_string
JWT_EXPIRATION_MINUTES=60
PLATFORM_OWNER_JWT_SECRET=change_me_platform_owner_must_be_long_random_string
PLATFORM_OWNER_JWT_EXPIRATION_MINUTES=60
RESELLER_JWT_SECRET=change_me_reseller_must_be_long_random_string
RESELLER_JWT_EXPIRATION_MINUTES=60

# RADIUS / CoA shared secret — must match what is in freeradius/clients.conf
RADIUS_COA_SECRET=radius_secret_123

# Shared secret for RADIUS accounting endpoint (internal API auth)
RADIUS_ACCOUNTING_SECRET=acct_secret_123

# 32-byte key for AES-256 encrypting NAS secrets at rest
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=NlvUlJ_LybSPZa-4oH0BjQHNM1yuNAw2Nn1CnyZ9Z8Q=

# Initial superadmin credentials (used by seed script only)
ADMIN_EMAIL=admin@isp.com
ADMIN_PASSWORD=admin123
PLATFORM_OWNER_EMAIL=owner@yourdomain.com
PLATFORM_OWNER_PASSWORD=change-me-strong-password

# Set to "true" to run seed on container start (first time only)
RUN_SEED=false

# --- Frontend (Admin Dashboard) ---
VITE_API_BASE_URL=http://localhost:8000/api/v1

# --- Payments ---
MTN_MOMO_BASE_URL=
MTN_MOMO_COLLECTION_SUBSCRIPTION_KEY=
MTN_MOMO_API_USER=
MTN_MOMO_API_KEY=
MTN_MOMO_ENVIRONMENT=sandbox

VODAFONE_CASH_BASE_URL=
VODAFONE_CASH_MERCHANT_ID=
VODAFONE_CASH_API_KEY=
VODAFONE_CASH_CALLBACK_URL=

AIRTELTIGO_BASE_URL=
AIRTELTIGO_CLIENT_ID=
AIRTELTIGO_CLIENT_SECRET=
AIRTELTIGO_CALLBACK_URL=

PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_CALLBACK_URL=
PAYSTACK_WEBHOOK_SECRET=

SMS_PROVIDER=hubtel
HUBTEL_CLIENT_ID=
HUBTEL_CLIENT_SECRET=
HUBTEL_FROM=
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=
AFRICASTALKING_FROM=

REDIS_URL=redis://redis:6379
WEBHOOK_BASE_URL=https://yourdomain.com
PORTAL_PUBLIC_BASE_URL=
LOG_FORMAT=console
LOG_LEVEL=INFO

# MikroTik
RADIUS_PUBLIC_HOST=
MIKROTIK_API_TIMEOUT=10
MIKROTIK_CMD_TIMEOUT=30

# --- Phase 2: Email ---
# Provider: "sendgrid" or "mailgun" (leave blank to disable email)
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@yourplatform.com
SENDGRID_FROM_NAME=YourISP Platform
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM_EMAIL=
PLATFORM_SUPPORT_EMAIL=support@yourplatform.com

# --- Phase 2: Platform billing (separate Paystack account for collecting operator fees) ---
PLATFORM_BILLING_PAYSTACK_PUBLIC_KEY=
PLATFORM_BILLING_PAYSTACK_SECRET_KEY=
PLATFORM_BILLING_PAYSTACK_WEBHOOK_SECRET=
PLATFORM_APP_URL=http://localhost:8000

# --- Phase 2: Billing config ---
DEFAULT_MONTHLY_FEE_GHS=200.00
TRIAL_DAYS=14
GRACE_PERIOD_DAYS=14

# --- WireGuard VPN tunnel (remote router management) ---
# Generated by scripts/setup_wireguard.sh on the server (run once).
WG_SERVER_PUBLIC_KEY=
WG_SERVER_PRIVATE_KEY=
WG_SERVER_ENDPOINT=34.122.11.114:51820   # your server's public IP:port (open UDP 51820)
WG_TUNNEL_NETWORK=10.100.0.0/24          # private network for tunnel IPs
WG_SERVER_TUNNEL_IP=10.100.0.1           # server's tunnel IP
WG_INTERFACE=wg0                          # WireGuard interface name
WG_MANAGER_URL=http://127.0.0.1:8999     # wg-manager sidecar (localhost only)
